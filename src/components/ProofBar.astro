---
const stats = [
  { value: 'Hundreds', label: 'of Automations' },
  { value: 'Any', label: 'Platform' },
  { value: '31', label: 'Workday Templates' },
  { value: '30 Years', label: 'Experience' },
];
---

<section class="bg-amber">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-charcoal">{stat.value}</div>
          <div class="text-sm font-medium text-charcoal/70 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
