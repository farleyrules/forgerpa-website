---
interface Props {
  title: string;
  date: string;
  readingTime: string;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, readingTime, description, tags, slug } = Astro.props;

const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="group block p-8 bg-white rounded-xl border border-gray-200 hover:border-amber shadow-sm hover:shadow-lg transition-all duration-300">
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.slice(0, 3).map((tag) => (
      <span class="text-xs font-medium px-2 py-1 bg-amber/10 text-amber-dark rounded">
        {tag}
      </span>
    ))}
  </div>
  <h3 class="text-xl font-bold text-charcoal mb-3 group-hover:text-amber-dark transition-colors leading-snug">
    {title}
  </h3>
  <p class="text-gray-600 leading-relaxed mb-4 line-clamp-3">
    {description}
  </p>
  <div class="flex items-center justify-between text-sm text-gray-400">
    <time datetime={date}>{formattedDate}</time>
    <span>{readingTime} read</span>
  </div>
</a>
