---
/**
 * Optional high-intent capture: send the resource bundle by email.
 * Set PUBLIC_FORMSPREE_TOOLKIT at build time (e.g. Cloudflare Pages env) to a Formspree endpoint, e.g.
 * https://formspree.io/f/xxxxxxxx
 * If unset, visitors see a mailto fallback to info@forgerpa.com.
 */
const formspreeUrl = (import.meta.env.PUBLIC_FORMSPREE_TOOLKIT as string | undefined)?.trim() ?? '';

const siteBase = ((import.meta.env.SITE as string | undefined) ?? 'https://forgerpa.com').replace(/\/$/, '');
const toolkitThanksUrl = `${siteBase}/resources/toolkit-thanks`;

const mailtoSubject = 'Forge RPA — toolkit bundle request';
const mailtoBody = `Hi Forge RPA,

Please email me direct links to the Finance Automation toolkit on forgerpa.com/resources:
- Assessment framework (Excel)
- ROI calculator (Excel)
- 5 High-ROI processes (PDF)
- Month-end close checklist (HTML)

Any short getting-started tips are appreciated.

My role:
Company:

Thank you.`;

const mailtoHref = `mailto:info@forgerpa.com?subject=${encodeURIComponent(mailtoSubject)}&body=${encodeURIComponent(mailtoBody)}`;
---

<section
  class="mt-16 rounded-2xl border-2 border-amber bg-gradient-to-br from-charcoal to-charcoal-light px-6 py-8 sm:px-10 sm:py-10 text-white shadow-lg shadow-charcoal/20"
  aria-labelledby="toolkit-bundle-heading"
>
  <h2 id="toolkit-bundle-heading" class="text-xl sm:text-2xl font-bold text-white mb-2">
    Save this lead + get instant downloads
  </h2>
  <p class="text-gray-300 text-sm sm:text-base leading-relaxed max-w-2xl mb-6">
    All files above stay <strong class="text-amber">one-click and ungated</strong>. If you submit this form (when
    enabled), Formspree notifies us and you are <strong class="text-white">immediately redirected</strong> to a thank-you
    page with the same four download links. No waiting for a manual email just to access the files. Optional follow-up
    stays limited to what you select below; we do not add you to a newsletter from this request.
  </p>

  {
    formspreeUrl ? (
      <form action={formspreeUrl} method="POST" class="max-w-xl space-y-4">
        <input type="hidden" name="_subject" value="Toolkit bundle request (forgerpa.com/resources)" />
        <input type="hidden" name="_next" value={toolkitThanksUrl} />
        <div>
          <label for="toolkit-email" class="block text-sm font-medium text-amber mb-1.5">
            Work email <span class="text-red-300">*</span>
          </label>
          <input
            id="toolkit-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-gray-600 bg-charcoal-light text-white placeholder:text-gray-500 focus:ring-2 focus:ring-amber focus:border-amber outline-none"
            placeholder="you@company.com"
          />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="toolkit-name" class="block text-sm font-medium text-gray-300 mb-1.5">Name (optional)</label>
            <input
              id="toolkit-name"
              type="text"
              name="name"
              autocomplete="name"
              class="w-full px-4 py-3 rounded-lg border border-gray-600 bg-charcoal-light text-white placeholder:text-gray-500 focus:ring-2 focus:ring-amber focus:border-amber outline-none"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="toolkit-company" class="block text-sm font-medium text-gray-300 mb-1.5">Company (optional)</label>
            <input
              id="toolkit-company"
              type="text"
              name="company"
              autocomplete="organization"
              class="w-full px-4 py-3 rounded-lg border border-gray-600 bg-charcoal-light text-white placeholder:text-gray-500 focus:ring-2 focus:ring-amber focus:border-amber outline-none"
              placeholder="Company"
            />
          </div>
        </div>
        <div class="flex items-start gap-2">
          <input
            id="toolkit-followup"
            type="checkbox"
            name="follow_up_ok"
            value="Yes — one follow-up about these tools is OK"
            class="mt-1 h-4 w-4 rounded border-gray-500 text-amber focus:ring-amber"
          />
          <label for="toolkit-followup" class="text-sm text-gray-300 leading-snug">
            I am OK with <strong class="text-white">one</strong> brief follow-up if something in the toolkit is unclear (not
            a marketing list).
          </label>
        </div>
        <button
          type="submit"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-amber hover:bg-amber-dark text-charcoal font-bold rounded-lg transition-colors shadow-md"
        >
          Submit and open downloads
        </button>
        <p class="text-xs text-gray-400 leading-relaxed">
          You will land on our thank-you page with the files right away. We receive your submission for follow-up only as
          needed. Book a call anytime at{' '}
          <a href="/book" class="text-amber underline hover:text-amber-light">forgerpa.com/book</a>.
        </p>
      </form>
    ) : (
      <div class="max-w-xl space-y-4">
        <p class="text-sm text-gray-300 leading-relaxed">
          Form endpoint is not configured yet. Tap below to send the same request from your email app (you can edit the
          message before sending).
        </p>
        <a
          href={mailtoHref}
          class="inline-flex items-center justify-center px-8 py-3.5 bg-amber hover:bg-amber-dark text-charcoal font-bold rounded-lg transition-colors shadow-md"
        >
          Request the toolkit by email
        </a>
        <p class="text-xs text-gray-400 leading-relaxed">
          For automated delivery, add <code class="text-gray-300">PUBLIC_FORMSPREE_TOOLKIT</code> in Cloudflare Pages
          environment variables at build time (see <code class="text-gray-300">.env.example</code>).
        </p>
      </div>
    )
  }
</section>
