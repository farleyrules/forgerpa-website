---
interface Props {
  calLink?: string;
}

const { calLink = '' } = Astro.props;
---

<div class="bg-gradient-to-br from-charcoal to-charcoal-light rounded-xl p-8 lg:p-12 text-center">
  <h3 class="text-2xl font-bold text-white mb-4">Book a Discovery Call</h3>
  <p class="text-gray-300 mb-8 max-w-lg mx-auto">
    30 minutes. No sales pitch. We will identify your top 3 automation candidates and estimate ROI using real data from your processes.
  </p>
  {calLink ? (
    <div class="bg-white rounded-lg p-4 max-w-xl mx-auto">
      <iframe src={calLink} class="w-full h-96 border-0" title="Schedule a call"></iframe>
    </div>
  ) : (
    <div class="space-y-4">
      <a href="mailto:david@forgerpa.com?subject=Discovery%20Call%20Request" class="inline-flex items-center justify-center px-8 py-4 bg-amber hover:bg-amber-dark text-charcoal font-bold text-lg rounded-lg transition-colors shadow-lg shadow-amber/20">
        Request a Call
      </a>
      <p class="text-sm text-gray-400">
        Calendar booking coming soon. Email us and we will schedule within 24 hours.
      </p>
    </div>
  )}
</div>
