---
interface Props {
  icon: string;
  title: string;
  description: string;
  link: string;
}

const { icon, title, description, link } = Astro.props;
---

<a href={link} class="group block p-8 bg-white rounded-xl border-2 border-gray-100 hover:border-amber shadow-sm hover:shadow-lg transition-all duration-300">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-xl font-bold text-charcoal mb-3 group-hover:text-amber-dark transition-colors">
    {title}
  </h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
  <div class="mt-6 text-amber-dark font-semibold text-sm flex items-center gap-2 group-hover:gap-3 transition-all">
    Learn More
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
