---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { label: 'Automation Assessment', href: '/services/automation-assessment' },
  { label: 'Workday Conversion', href: '/services/workday-conversion' },
  { label: 'SOP Automation', href: '/services/sop-automation' },
  { label: 'Process Mining', href: '/services/process-mining' },
];
---

<footer class="bg-charcoal text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand Column -->
      <div>
        <a href="/" class="text-2xl font-bold text-amber">ForgeRPA</a>
        <p class="mt-4 text-gray-400 leading-relaxed">
          Intelligent automation built by a CPA who codes.
        </p>
        <p class="mt-6 text-sm text-gray-500">
          &copy; {currentYear} ForgeRPA. All rights reserved.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-amber transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold mb-4">Get in Touch</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:david@forgerpa.com" class="hover:text-amber transition-colors">
              david@forgerpa.com
            </a>
          </li>
          <li>
            <a href="https://linkedin.com/in/davidfarleyabs" target="_blank" rel="noopener noreferrer" class="hover:text-amber transition-colors">
              LinkedIn
            </a>
          </li>
          <li>Frisco, Texas</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-sm text-gray-500">
        ForgeRPA respects your privacy. We do not sell your data or use tracking cookies beyond essential site functionality.
      </p>
    </div>
  </div>
</footer>
