---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const { title, subtitle, ctaText, ctaLink, secondaryCtaText, secondaryCtaLink } = Astro.props;
---

<section id="page-hero" class="relative bg-gradient-to-br from-charcoal to-charcoal-light overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, #f59e0b 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
    <div class="max-w-3xl">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-6 text-lg sm:text-xl text-gray-300 leading-relaxed max-w-2xl">
          {subtitle}
        </p>
      )}
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        {ctaText && ctaLink && (
          <a href={ctaLink} class="inline-flex items-center justify-center px-8 py-4 bg-amber hover:bg-amber-dark text-charcoal font-bold text-lg rounded-lg transition-colors shadow-lg shadow-amber/20">
            {ctaText}
          </a>
        )}
        {secondaryCtaText && secondaryCtaLink && (
          <a href={secondaryCtaLink} class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-500 hover:border-amber text-white hover:text-amber font-semibold text-lg rounded-lg transition-colors">
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
