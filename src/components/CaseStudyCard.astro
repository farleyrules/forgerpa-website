---
interface Props {
  industry: string;
  metric: string;
  description: string;
  link: string;
}

const { industry, metric, description, link } = Astro.props;
---

<a href={link} class="group block p-8 bg-white rounded-xl border border-gray-200 hover:border-amber shadow-sm hover:shadow-lg transition-all duration-300">
  <span class="inline-block px-3 py-1 text-xs font-semibold bg-charcoal text-amber rounded-full mb-4">
    {industry}
  </span>
  <div class="text-2xl font-bold text-charcoal mb-3 group-hover:text-amber-dark transition-colors">
    {metric}
  </div>
  <p class="text-gray-600 leading-relaxed">{description}</p>
  <div class="mt-6 text-amber-dark font-semibold text-sm flex items-center gap-2 group-hover:gap-3 transition-all">
    Read Case Study
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
