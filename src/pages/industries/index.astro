---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';

const industries = [
  {
    href: '/industries/oil-gas',
    title: 'Oil & Gas',
    description:
      'Revenue accounting, JVs, operations-to-finance handoffs, materials and field ticketing bridges, and close-critical reporting.',
  },
  {
    href: '/industries/healthcare-finance',
    title: 'Healthcare Finance & Ops',
    description:
      'Non-PHI scope: finance close, payer files, supply chain finance, facilities cost feeds — finance-owned and non-clinical operations data.',
  },
  {
    href: '/industries/insurance-finance',
    title: 'Insurance',
    description:
      'Allocations, subledgers, claims ops finance files, underwriting support assembly, and governed reporting.',
  },
  {
    href: '/industries/utilities-finance',
    title: 'Utilities & infrastructure',
    description:
      'Month-end, work orders, field events, WIP and regulatory extracts — finance and field operations together.',
  },
  {
    href: '/industries/small-business',
    title: 'Small and Growing Businesses',
    description:
      'Assessment-first engagements, per-solution builds, optional retainer when you want Hub support without adding IT headcount.',
  },
];
---

<PageLayout
  title="Industries | Forge RPA"
  description="Accounting, finance, and operations automation across industries — oil and gas, healthcare, insurance, utilities, and SMB. Industry pages highlight typical pain points; your roadmap still starts with discovery."
  heroTitle="Industry solutions"
  heroSubtitle="Vertical pages show how we think about your world — not a limit on where we work. Every organization has accounting &amp; finance and operations friction we can help with; over time we add sharper industry examples as we ship more work."
  heroCta="Book a Discovery Call"
  heroCtaLink="/book?from=industries-overview"
>
  <section class="py-16 lg:py-20 bg-slate-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-6">Every industry runs on A&amp;F and operations</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Regardless of sector, leadership cares about the same underlying problems: <strong>month-end integrity</strong>,{' '}
        <strong>order-to-cash and procure-to-pay discipline</strong>, <strong>reconciliations that tie</strong>,{' '}
        <strong>handoffs between the field and the ledger</strong>, and <strong>evidence when auditors or regulators ask</strong>.
        Our deepest craft is finance-grade automation — and we apply the same rigor to <strong>operations and administrative</strong> flows
        (supply chain paperwork, vendor onboarding, scheduling data, inventory interfaces, HR ops where data is non-PHI, and more) when they are rules-based and systems-accessible.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed">
        The industry tiles below are <strong>starting lenses</strong>: concrete pain language so visitors from that sector see themselves quickly.
        If your industry is not listed yet, the conversation is the same — we map your processes, then prioritize what to automate first.
      </p>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-charcoal mb-10 text-center">Explore by industry</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {industries.map((item) => (
          <a
            href={item.href}
            class="block bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors"
          >
            <h2 class="text-2xl font-bold text-charcoal mb-3">{item.title}</h2>
            <p class="text-gray-600 leading-relaxed mb-4">{item.description}</p>
            <span class="text-amber-dark font-semibold">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Not sure where you fit?"
    subtext="Most of our work still centers on month-end, subledgers, ERP data flows, and the operations handoffs that feed them. Book a call and we will map your processes to the right tools."
    ctaText="Book a Discovery Call"
    ctaLink="/book?from=industries-overview"
  />
</PageLayout>
