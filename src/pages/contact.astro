---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import CalEmbed from '../components/CalEmbed.astro';
---

<PageLayout
  title="Contact or Book a Call | Forge RPA"
  description="Book your discovery call or send us a message. Primary scheduling is now via our dedicated booking page."
  heroTitle="Let's Talk Automation"
  heroSubtitle="Book a 30-minute discovery call on our dedicated /book page or send us a message below. We respond within 24 hours."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-6">Send a Message</h2>
          <ContactForm />
        </div>

        <!-- Contact Info + Cal Embed -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-charcoal mb-6">Contact Information</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-amber-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-charcoal">Email</h3>
                  <a href="mailto:info@forgerpa.com" class="text-amber-dark hover:underline">info@forgerpa.com</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-amber-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-charcoal">Location</h3>
                  <p class="text-gray-600">Frisco, Texas</p>
                </div>
              </div>
            </div>
          </div>

          <CalEmbed />
        </div>
      </div>
    </div>
  </section>
</PageLayout>
