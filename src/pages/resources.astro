---
import PageLayout from '../layouts/PageLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<PageLayout
  title="Resources | Forge RPA"
  description="Free tools and guides for finance and accounting automation. Download our assessment worksheets, checklists, and ROI calculators."
  heroTitle="Resources for Finance Leaders"
  heroSubtitle="Practical tools and insights developed from real finance operations experience. Proven in finance but applicable to other operational processes."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">Free Tools &amp; Guides</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Download practical resources developed from 30 years of financial operations experience. 
          These tools are designed to help you assess automation opportunities and build momentum in your finance transformation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Lead Magnet 1 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📋</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Finance Automation Assessment Framework</h3>
          <p class="text-gray-600 mb-6">
            Our proprietary six-criterion scoring framework used to evaluate finance processes for automation potential, 
            ROI projection, and recommended approach. Includes Excel template with built-in calculations and benchmarks.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">Excel Template + Guide (Instant Download)</span>
            <a href="/contact" 
               class="inline-flex items-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors">
              Download Framework
            </a>
          </div>
        </div>

        <!-- Lead Magnet 2 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📊</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Month-End Close Optimization Checklist</h3>
          <p class="text-gray-600 mb-6">
            47-point checklist based on real finance operations experience. Identifies the most common bottlenecks 
            in month-end close processes with specific automation opportunities and estimated time savings for each.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">PDF Checklist + Framework Notes</span>
            <a href="/contact" 
               class="inline-flex items-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors">
              Download Checklist
            </a>
          </div>
        </div>

        <!-- Lead Magnet 3 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">🎯</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">5 High-ROI Finance Processes to Automate</h3>
          <p class="text-gray-600 mb-6">
            Practical guide based on real implementations. Details the five finance processes that consistently deliver 
            the highest ROI, with specific examples, typical time savings, implementation approach, and expected returns.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">PDF Guide with Real Examples</span>
            <a href="/contact" 
               class="inline-flex items-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors">
              Download Guide
            </a>
          </div>
        </div>

        <!-- Lead Magnet 4 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📈</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Finance Automation ROI Calculator</h3>
          <p class="text-gray-600 mb-6">
            Interactive Excel tool that helps you estimate potential ROI for common finance processes. 
            Includes benchmarks from our framework implementations across multiple industries.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">Excel Template with Framework Benchmarks</span>
            <a href="/contact" 
               class="inline-flex items-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors">
              Get the Calculator
            </a>
          </div>
        </div>
      </div>

      <div class="mt-16 text-center">
        <p class="text-gray-600 mb-6">
          All resources are free and instant. No email gatekeeping — just practical tools to help you move faster.
        </p>
        <p class="text-sm text-gray-500">
          These tools were developed from 30 years of real finance operations experience and refined through our proprietary framework. Proven in finance but applicable to other operational processes.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a 30-minute discovery call. We'll review your specific challenges and show you how our framework can deliver results."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
---