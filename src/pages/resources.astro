---
import PageLayout from '../layouts/PageLayout.astro';
import CTASection from '../components/CTASection.astro';

const downloads = {
  assessment: '/downloads/forgerpa-finance-automation-assessment-framework.xlsx',
  checklist: '/downloads/forgerpa-month-end-close-checklist.html',
  guide: '/downloads/forgerpa-5-high-roi-finance-processes.pdf',
  roi: '/downloads/forgerpa-finance-automation-roi-calculator.xlsx',
} as const;
---

<PageLayout
  title="Resources | Forge RPA"
  description="Free tools and guides for finance, accounting, and operations automation. Download our assessment worksheets, checklists, and ROI calculators."
  heroTitle="Resources for Finance and Operations Leaders"
  heroSubtitle="Practical tools and insights developed from real finance operations experience—with the same discipline applied to operations and administrative automation when work is rules-based and systems-accessible."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">Free Tools &amp; Guides</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Download practical resources developed from 30 years of financial operations experience.
          These tools are designed to help you assess automation opportunities and build momentum in your finance and operations transformation.
        </p>
        <p class="mt-4 text-sm text-gray-500 max-w-2xl mx-auto">
          Want to talk through your scores or roadmap?{' '}
          <a href="/book" class="text-amber-dark hover:text-amber font-semibold">Book a 30-minute discovery call</a>.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📋</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Finance Automation Assessment Framework</h3>
          <p class="text-gray-600 mb-6">
            Six-criterion weighted scoring to evaluate finance processes for automation potential, plus a short interpretation
            guide. Includes process inventory rows and calculated weighted scores.
          </p>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <span class="text-sm text-gray-500">Microsoft Excel (.xlsx)</span>
            <a
              href={downloads.assessment}
              download
              class="inline-flex items-center justify-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors"
            >
              Download framework
            </a>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📊</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Month-End Close Optimization Checklist</h3>
          <p class="text-gray-600 mb-6">
            Forty-seven checkpoints across pre-close, execution, reconciliations, reporting, and post-close improvement. Each
            line is written with automation and control ownership in mind.
          </p>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <span class="text-sm text-gray-500">HTML — open file, then Print → Save as PDF</span>
            <a
              href={downloads.checklist}
              class="inline-flex items-center justify-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors"
            >
              Open checklist
            </a>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">🎯</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">5 High-ROI Finance Processes to Automate</h3>
          <p class="text-gray-600 mb-6">
            A concise guide covering five process families that routinely produce strong returns when data and ownership are
            aligned: AP match, reconciliations, close packs, intercompany support, and operational reporting pulls.
          </p>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <span class="text-sm text-gray-500">PDF guide</span>
            <a
              href={downloads.guide}
              download
              class="inline-flex items-center justify-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors"
            >
              Download guide
            </a>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-amber transition-colors">
          <div class="text-amber text-4xl mb-6">📈</div>
          <h3 class="text-2xl font-bold text-charcoal mb-3">Finance Automation ROI Calculator</h3>
          <p class="text-gray-600 mb-6">
            Illustrative workbook: enter hours removed per month, loaded hourly cost, adoption, implementation spend, and
            annual run-state costs. Outputs monthly and annual labor savings, year-one net, and simple payback on
            implementation.
          </p>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <span class="text-sm text-gray-500">Microsoft Excel (.xlsx)</span>
            <a
              href={downloads.roi}
              download
              class="inline-flex items-center justify-center px-6 py-3 bg-amber hover:bg-amber-dark text-charcoal font-semibold rounded-lg transition-colors"
            >
              Get the calculator
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">
          All files above are free, instant, and <strong class="text-charcoal">ungated</strong>. Use them on your own timeline.
          When you are ready to discuss priorities, book a discovery call — we will use the contact details you provide in Cal.com.
        </p>
        <p class="text-sm text-gray-500">
          These tools were developed from real finance operations experience and refined through our proprietary framework.
          Proven in finance but applicable to other operational processes.
        </p>
        <p class="mt-4 text-xs text-gray-500">
          Files are regenerated from <code class="text-gray-600">scripts/build_lead_magnets.py</code> when we update templates.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a 30-minute discovery call. We'll review your specific challenges and show you how our framework can deliver results."
    ctaText="Book a Discovery Call"
    ctaLink="/book"
  />
</PageLayout>
