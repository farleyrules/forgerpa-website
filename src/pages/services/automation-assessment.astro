---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<PageLayout
  title="Automation Assessment"
  description="Data-driven process scoring, ROI projections, and prioritized automation roadmaps. Delivered in 3 weeks."
  heroTitle="Know Exactly What to Automate First"
  heroSubtitle="A data-driven assessment that scores finance and operations processes for automation potential, projects ROI, and delivers a prioritized roadmap — so you invest in the right automations from day one."
  heroCta="Book your assessment consultation"
  heroCtaLink="/book?from=assessment"
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- What It Is -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">What It Is</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          Our Automation Assessment evaluates your finance and accounting processes using a six-criterion scoring framework developed across numerous finance transformations. Every process receives a weighted score that predicts automation success, estimated ROI, and recommended technology approach.
        </p>
        <p class="mt-4 text-lg text-gray-700 leading-relaxed">
          This is the same framework we have used at Fortune 500 manufacturers to prioritize automations across departments. It removes guesswork and ensures your automation investment delivers the fastest possible return. This helps determine how well each process can be automated using the right combination of tools for your environment, from Microsoft 365 capabilities to targeted RPA and ERP automation.
        </p>
      </div>

      <!-- What You Receive -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">What You Receive</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="text-amber-dark font-bold">1</span>
            </div>
            <div>
              <h3 class="font-bold text-charcoal">Process Inventory</h3>
              <p class="text-gray-600 mt-1">Complete catalog of processes with time estimates, systems involved, and current pain points.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="text-amber-dark font-bold">2</span>
            </div>
            <div>
              <h3 class="font-bold text-charcoal">Automation Scoring</h3>
              <p class="text-gray-600 mt-1">Each process scored on rule complexity, volume, data structure, stability, error impact, and technology compatibility.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="text-amber-dark font-bold">3</span>
            </div>
            <div>
              <h3 class="font-bold text-charcoal">ROI Projections</h3>
              <p class="text-gray-600 mt-1">Conservative, moderate, and aggressive ROI scenarios with payback period estimates for each candidate.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="text-amber-dark font-bold">4</span>
            </div>
            <div>
              <h3 class="font-bold text-charcoal">Technology Recommendations</h3>
              <p class="text-gray-600 mt-1">The optimal automation technology matched to each process based on technical requirements, cost, and maintainability.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-amber/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="text-amber-dark font-bold">5</span>
            </div>
            <div>
              <h3 class="font-bold text-charcoal">Implementation Roadmap</h3>
              <p class="text-gray-600 mt-1">Prioritized sequence of automations with timeline, budget estimates, and dependency mapping.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- How It Works -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-slate-light rounded-xl p-8 text-center">
            <div class="text-3xl font-extrabold text-amber mb-2">Week 1</div>
            <h3 class="font-bold text-charcoal mb-2">Discovery</h3>
            <p class="text-gray-600 text-sm">Stakeholder interviews, process observation, SOP review, and system inventory.</p>
          </div>
          <div class="bg-slate-light rounded-xl p-8 text-center">
            <div class="text-3xl font-extrabold text-amber mb-2">Week 2</div>
            <h3 class="font-bold text-charcoal mb-2">Analysis</h3>
            <p class="text-gray-600 text-sm">AI-powered process scoring, ROI modeling, technology matching, and roadmap development.</p>
          </div>
          <div class="bg-slate-light rounded-xl p-8 text-center">
            <div class="text-3xl font-extrabold text-amber mb-2">Week 3</div>
            <h3 class="font-bold text-charcoal mb-2">Delivery</h3>
            <p class="text-gray-600 text-sm">Executive presentation, detailed report, and implementation roadmap with Q&A.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <CTASection
    heading="Stop Guessing. Start Measuring."
    subtext="Book a 30-minute consultation to confirm fit, scope, and timing for a formal Automation Assessment. Same calendar as our discovery calls, with the conversation centered on scoring, ROI, and roadmap work."
    ctaText="Book your assessment consultation"
    ctaLink="/book?from=assessment"
  />
</PageLayout>
