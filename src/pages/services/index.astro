---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<PageLayout
  title="Finance & Operations Automation Services"
  description="Automation assessment, finance and operations process automation, ERP data migration, and process mining. Advanced Excel, VBA, Power Query, and RPA solutions for accounting and operations teams."
  heroTitle="Finance & Operations Automation Services"
  heroSubtitle="We help Controllers, CFOs, and finance operations teams—and operations partners whose work feeds the ledger—cut manual effort across close, AP, reconciliations, reporting, ERP data, and governed operational handoffs (vendor and master-data flows, scheduling and inventory interfaces, field events, and similar rules-based workflows)."
  heroCta="Book a Discovery Call"
  heroCtaLink="/book"
>
  <!-- Service Lines -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">Core Finance &amp; Operations Services</h2>
        <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
          Our deepest craft is finance-grade automation—and we apply the same rigor to operations and administrative flows when they are rules-based and systems-accessible. Our work spans SAP, Workday, NetSuite, Ariba, Lawson, Hyperion, and advanced Excel, VBA &amp; Power Query solutions across manufacturing, utilities, healthcare, and financial services. See dedicated pages for{' '}
          <a href="/industries/oil-gas" class="text-amber-dark hover:text-amber font-semibold">oil &amp; gas</a>,{' '}
          <a href="/industries/healthcare-finance" class="text-amber-dark hover:text-amber font-semibold">healthcare finance &amp; ops</a>,{' '}
          <a href="/industries/insurance-finance" class="text-amber-dark hover:text-amber font-semibold">insurance</a>, and{' '}
          <a href="/industries/utilities-finance" class="text-amber-dark hover:text-amber font-semibold">utilities</a>,{' '}
          <a href="/industries/small-business" class="text-amber-dark hover:text-amber font-semibold">small and growing businesses</a> — or the full{' '}
          <a href="/industries" class="text-amber-dark hover:text-amber font-semibold">industries overview</a> (every sector has A&amp;F and operations pain we can map).
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Automation Assessment</h3>
          <p class="text-gray-600 mb-8">Data-driven process scoring, ROI projections, and prioritized automation roadmaps for finance, accounting, and operations teams—especially where work touches month-end, master data, or handoffs into finance.</p>
          <a href="/services/automation-assessment" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Finance &amp; Operations Process Automation</h3>
          <p class="text-gray-600 mb-8">Transform complex finance and adjacent operations processes into reliable automation using advanced Excel, VBA, Power Query, and targeted RPA tools.</p>
          <a href="/services/sop-automation" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">ERP Data Migration</h3>
          <p class="text-gray-600 mb-8">Clean, accurate data conversion for Workday, SAP, NetSuite, Ariba, Lawson and other systems with full reconciliation and validation—finance-owned and operations-sourced data when your security model allows.</p>
          <a href="/services/erp-data-migration" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Process Mining</h3>
          <p class="text-gray-600 mb-8">Discover how finance and operations processes actually work. Identify bottlenecks, exceptions, and high-ROI automation opportunities using real transaction and event data.</p>
          <a href="/services/process-mining" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    heading="Ready to Reduce Manual Finance &amp; Operations Work?"
    subtext="Book a free 30-minute discovery call. We will help you identify the highest-ROI opportunities in your month-end close, AP, reporting, and governed operational handoffs."
    ctaText="Book a Discovery Call"
    ctaLink="/book"
  />
</PageLayout>
