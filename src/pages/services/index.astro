---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<PageLayout
  title="Finance & Accounting Automation Services"
  description="Automation assessment, finance process automation, ERP data migration, and process mining for accounting teams. Advanced Excel, VBA, Power Query, and RPA solutions."
  heroTitle="Finance & Accounting Automation Services"
  heroSubtitle="We help Controllers, CFOs, and finance operations teams eliminate manual work in month-end close, accounts payable, reconciliations, reporting, and ERP data processes."
  heroCta="Book a Discovery Call"
  heroCtaLink="/contact"
>
  <!-- Service Lines -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">Core Finance Automation Services</h2>
        <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
          Proven in finance but applicable to other operational processes. Our work spans SAP, Workday, NetSuite, Ariba, Lawson, Hyperion, and advanced Excel, VBA &amp; Power Query solutions across manufacturing, utilities, healthcare, and financial services.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Automation Assessment</h3>
          <p class="text-gray-600 mb-8">Data-driven process scoring, ROI projections, and prioritized automation roadmaps specifically designed for finance and accounting teams.</p>
          <a href="/services/automation-assessment" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Finance Process Automation</h3>
          <p class="text-gray-600 mb-8">Transform complex finance processes into reliable automation using advanced Excel, VBA, Power Query, and targeted RPA tools.</p>
          <a href="/services/sop-automation" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">ERP Data Migration</h3>
          <p class="text-gray-600 mb-8">Clean, accurate data conversion for Workday, SAP, NetSuite, Ariba, Lawson and other systems with full reconciliation and validation.</p>
          <a href="/services/erp-data-migration" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:border-amber transition-colors">
          <h3 class="text-2xl font-bold text-charcoal mb-4">Process Mining</h3>
          <p class="text-gray-600 mb-8">Discover how your finance processes actually work. Identify bottlenecks, exceptions, and high-ROI automation opportunities using real transaction data.</p>
          <a href="/services/process-mining" class="text-amber-dark hover:text-amber font-semibold flex items-center gap-2">
            Learn More →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a free 30-minute discovery call. We will help you identify the highest-ROI opportunities in your month-end close, AP, and reporting processes."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
