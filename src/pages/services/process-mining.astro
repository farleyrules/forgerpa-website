---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<PageLayout
  title="Process Mining"
  description="Data-driven process discovery for finance and accounting operations. Identify bottlenecks and automation opportunities using actual transaction data."
  heroTitle="Process Mining for Finance Operations"
  heroSubtitle="Process mining reveals how your finance and accounting processes actually work. We analyze real transaction data from your systems to identify bottlenecks, exceptions, and high-value automation opportunities."
  heroCta="Start Mining"
  heroCtaLink="/contact"
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- What It Is -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">What It Is</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          Process mining uses event log data from your ERP and accounting systems to reconstruct how processes actually execute. Every transaction, every handoff, and every delay is captured and visualized. The result is an objective, data-driven view of your finance operations.
        </p>
        <p class="mt-4 text-lg text-gray-700 leading-relaxed">
          This approach reveals hidden bottlenecks, manual workarounds, and high-value automation opportunities that traditional process reviews often miss.
        </p>
      </div>

      <!-- How It Works -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">How It Works</h2>
        <div class="space-y-8">
          {[
            { stage: 'Data Extraction', desc: 'We extract event logs from your ERP, workflow systems, and databases. Every transaction creates a trail — we follow it.' },
            { stage: 'Process Discovery', desc: 'Algorithms reconstruct the actual process flow from event data. No interviews needed. No assumptions. Just data.' },
            { stage: 'Conformance Checking', desc: 'We compare the discovered process against your documented SOPs to identify deviations, workarounds, and undocumented steps.' },
            { stage: 'Bottleneck Analysis', desc: 'Statistical analysis identifies where delays accumulate, which handoffs create friction, and which steps generate rework.' },
            { stage: 'Automation Opportunity Mapping', desc: 'Every process segment is scored for automation potential using our six-criterion framework, with ROI projections.' },
          ].map((item, i) => (
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 bg-amber rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-charcoal font-bold">{i + 1}</span>
              </div>
              <div>
                <h3 class="text-xl font-bold text-charcoal">{item.stage}</h3>
                <p class="text-gray-600 mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Sample Findings -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">What We Typically Find</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { finding: 'Hidden rework loops', detail: '15-30% of transactions cycle through the same steps multiple times.' },
            { finding: 'Approval bottlenecks', detail: 'One manager becomes a single point of delay for dozens of processes.' },
            { finding: 'Undocumented workarounds', detail: 'Staff bypass official procedures — sometimes for good reasons that should be formalized.' },
            { finding: 'Automation sweet spots', detail: 'High-volume, rule-based segments that are perfect for immediate automation.' },
          ].map((item) => (
            <div class="bg-charcoal rounded-xl p-6">
              <h3 class="font-bold text-amber mb-2">{item.finding}</h3>
              <p class="text-gray-400 text-sm">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <CTASection
    heading="Stop Guessing Where the Bottlenecks Are"
    subtext="Process mining shows you exactly where work gets stuck and where automation will have the biggest impact."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
