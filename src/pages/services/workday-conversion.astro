---
import PageLayout from '../../layouts/PageLayout.astro';
import PricingTier from '../../components/PricingTier.astro';
import CTASection from '../../components/CTASection.astro';
---

<PageLayout
  title="Workday Data Conversion"
  description="31 pre-built iLoad templates, 8 source system mappings, and reconciliation-verified accuracy for Workday implementations."
  heroTitle="Workday Data Conversion Without the Guesswork"
  heroSubtitle="31 pre-built iLoad templates. 8 source system mappings. Reconciliation-verified accuracy. Get your data into Workday right the first time."
  heroCta="Discuss Your Migration"
  heroCtaLink="/contact"
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- The Problem -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">The Problem</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          Workday implementations fail at data conversion more than any other phase. Legacy system data does not map cleanly to Workday's data model. Field formats differ. Business rules conflict. And every error that makes it into production creates downstream problems that compound across modules.
        </p>
        <p class="mt-4 text-lg text-gray-700 leading-relaxed">
          Most implementation partners treat data conversion as a secondary workstream. We treat it as the foundation. Because when your data is wrong, everything built on top of it is wrong too.
        </p>
      </div>

      <!-- The Solution -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">The Solution</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          Our conversion engine uses pre-built iLoad templates that have been validated across multiple implementations. Every template handles field mapping, data transformation, validation rules, and error reporting — so your data arrives in Workday clean, complete, and audit-ready.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          <div class="bg-charcoal rounded-xl p-6 text-center">
            <div class="text-4xl font-extrabold text-amber">31</div>
            <div class="text-gray-400 mt-2">iLoad Templates</div>
          </div>
          <div class="bg-charcoal rounded-xl p-6 text-center">
            <div class="text-4xl font-extrabold text-amber">8</div>
            <div class="text-gray-400 mt-2">Source Systems</div>
          </div>
          <div class="bg-charcoal rounded-xl p-6 text-center">
            <div class="text-4xl font-extrabold text-amber">7</div>
            <div class="text-gray-400 mt-2">Workday Modules</div>
          </div>
        </div>
      </div>

      <!-- Source Systems -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">Supported Source Systems</h2>
        <div class="flex flex-wrap gap-3">
          {['SAP', 'Oracle', 'PeopleSoft', 'ADP', 'Kronos', 'NetSuite', 'QuickBooks', 'Custom/Legacy'].map((system) => (
            <span class="px-4 py-2 bg-amber/10 text-amber-dark font-medium rounded-lg text-sm">
              {system}
            </span>
          ))}
        </div>
      </div>

      <!-- Finance Expertise Differentiator -->
      <div class="mb-16 bg-gradient-to-br from-charcoal to-charcoal-light rounded-xl p-8 lg:p-12">
        <h2 class="text-2xl font-bold text-amber mb-4">The Finance Expertise Advantage</h2>
        <p class="text-gray-300 leading-relaxed">
          Most data conversion specialists are technicians. They can map fields and transform formats. But they cannot tell you when a journal entry mapping will create a downstream audit issue, or when a cost center structure will break your financial reporting hierarchy.
        </p>
        <p class="text-gray-300 leading-relaxed mt-4">
          Our team brings decades of hands-on experience managing Workday financials in production. We verify every conversion from both the technical and accounting perspective. Your auditors will not find surprises in your converted data.
        </p>
      </div>

      <!-- Pricing -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-charcoal mb-6">Engagement Models</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <PricingTier
            name="Assessment Only"
            price="$5K - $10K"
            deliverables={[
              'Source system analysis',
              'Data quality assessment',
              'Migration complexity scoring',
              'Timeline and budget estimate',
            ]}
          />
          <PricingTier
            name="Conversion"
            price="$25K - $100K"
            deliverables={[
              'Full data extraction',
              'Template-based transformation',
              'Validation and error correction',
              'Parallel testing support',
              '3 mock conversion cycles',
            ]}
            featured={true}
          />
          <PricingTier
            name="Full Support"
            price="$50K - $200K"
            deliverables={[
              'End-to-end conversion',
              'Custom template development',
              'Cutover planning and execution',
              'Go-live hypercare (4 weeks)',
              'Post-conversion audit support',
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Get Your Data Right the First Time"
    subtext="Schedule a call to discuss your Workday migration timeline and data conversion requirements."
    ctaText="Discuss Your Migration"
    ctaLink="/contact"
  />
</PageLayout>
