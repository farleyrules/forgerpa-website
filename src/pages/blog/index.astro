---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout
  title="Blog"
  description="Finance automation insights from a CPA who codes. ROI frameworks, technology comparisons, and practical guides."
  heroTitle="Finance Automation Insights"
  heroSubtitle="Practical guides, ROI frameworks, and honest perspectives on automation — from a CPA who has built 100+ automations."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            readingTime={post.data.readingTime}
            description={post.data.description}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
