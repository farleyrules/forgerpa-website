---
import PageLayout from '../layouts/PageLayout.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
---

<PageLayout
  title="Intelligent Automation by People Who Understand Your Operations"
  description="AI-powered automation assessment, process conversion, and Workday data migration — built by professionals who actually understand your data."
  heroTitle="Accelerate Your Operations with Intelligent Automation"
  heroSubtitle="AI-powered automation assessment, process conversion, and Workday data migration — built by professionals who actually understand your data."
  heroCta="Book a Discovery Call"
  heroCtaLink="/contact"
>
  <!-- Proof Bar -->
  <ProofBar />

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">What We Build</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Four service lines, one goal: measurable ROI from automation.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ServiceCard
          icon="📊"
          title="Automation Assessment"
          description="Not sure where to start? We score your processes, project the ROI, and show you exactly which automations will pay for themselves first."
          link="/services/automation-assessment"
        />
        <ServiceCard
          icon="🔄"
          title="ERP Data Migration"
          description="Template-driven data conversion for Workday, NetSuite, SAP, and more. Reconciliation-verified accuracy."
          link="/services/erp-data-migration"
        />
        <ServiceCard
          icon="⚙️"
          title="SOP Automation"
          description="Your team already documented the process. We turn those SOPs into working automation. In weeks, not months."
          link="/services/sop-automation"
        />
        <ServiceCard
          icon="🔍"
          title="Process Mining"
          description="See how work actually flows. Find bottlenecks. Identify automation opportunities."
          link="/services/process-mining"
        />
      </div>
    </div>
  </section>

  <!-- What You Can Expect Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">What You Can Expect</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Typical outcomes from our automation engagements.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <CaseStudyCard
          industry="Process Efficiency"
          metric="70-95% time reduction"
          description="Manual processes that took hours compressed to minutes. Your team focuses on analysis and strategy instead of data entry."
          link="/contact"
        />
        <CaseStudyCard
          industry="Cost Savings"
          metric="ROI in weeks, not years"
          description="Most engagements pay for themselves within 3-6 months. Savings compound as maintenance costs stabilize."
          link="/contact"
        />
        <CaseStudyCard
          industry="Risk Reduction"
          metric="Near-zero error rates"
          description="Automated validation catches errors before they reach production. Compliance gaps close. Audit findings get resolved."
          link="/contact"
        />
      </div>
    </div>
  </section>

  <!-- Why ForgeRPA Section -->
  <section class="py-20 lg:py-28 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Why ForgeRPA</h2>
        <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
          Not another consulting firm.<br />A hands-on team that understands your operations.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🎓</div>
          <h3 class="text-lg font-bold text-amber mb-2">30 Years in the Trenches</h3>
          <p class="text-gray-400 text-sm">We have lived your processes. Closed the books, managed the teams, fought the fires. We also learned to automate all of it.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="text-lg font-bold text-amber mb-2">Works With Your Stack</h3>
          <p class="text-gray-400 text-sm">Already using RPA software, BI tools, or ERP systems? We build on what you have. Starting fresh?<br />Our proprietary approach can significantly reduce the licensing costs typically associated with automation.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🏭</div>
          <h3 class="text-lg font-bold text-amber mb-2">Hundreds of Automations</h3>
          <p class="text-gray-400 text-sm">Deployed across industries.<br />If your team runs a repeatable process, we can automate it. Battle-tested patterns and production-proven architecture.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🔑</div>
          <h3 class="text-lg font-bold text-amber mb-2">You Own Everything</h3>
          <p class="text-gray-400 text-sm">Full source code,<br />documentation,<br />and training.<br />No vendor lock-in.<br />No surprise costs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    heading="Find Your First $50K in Savings"
    subtext="Book a free 30-minute discovery call. We will identify your top 3 automation candidates and estimate payback periods using real data."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
