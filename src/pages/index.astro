---
import PageLayout from '../layouts/PageLayout.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
import { getCollection } from 'astro:content';
const featuredStudies = await getCollection('case-studies', ({ data }) => data.featured === true);
const sortedFeatured = featuredStudies
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 3);
---

<PageLayout
  title="Finance & Accounting Automation | ForgeRPA"
  description="Practical automation for finance and accounting teams. We help companies of all sizes eliminate manual work in month-end close, AP processing, reconciliations, and reporting."
  heroTitle="Finance Automation That Delivers Real Results"
  heroSubtitle="We combine deep finance operations experience with practical automation expertise to help companies of all sizes reduce manual work and improve accuracy."
  heroCta="Book a Discovery Call"
  heroCtaLink="/contact"
>
  <!-- Proof Bar -->
  <ProofBar />

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">What We Build</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Specialized automation for finance and accounting processes — from quick assessments to full system implementations. Whether you're a growing business or an established enterprise, we help finance teams eliminate manual work and focus on higher-value activities.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ServiceCard
          icon="📊"
          title="Automation Assessment"
          description="Not sure where to start? We score your processes, project the ROI, and show you exactly which automations will deliver the fastest return."
          link="/services/automation-assessment"
        />
        <ServiceCard
          icon="🔄"
          title="ERP Data Migration"
          description="Reliable data conversion for Workday, NetSuite, SAP and other systems. Reconciliation-verified accuracy with minimal disruption."
          link="/services/erp-data-migration"
        />
        <ServiceCard
          icon="⚙️"
          title="SOP Automation"
          description="Turn your documented procedures into working automation. Faster implementation with solutions that match how your team actually works."
          link="/services/sop-automation"
        />
        <ServiceCard
          icon="🔍"
          title="Process Mining"
          description="Discover how work actually gets done. Identify bottlenecks, inefficiencies, and high-ROI automation opportunities."
          link="/services/process-mining"
        />
      </div>
    </div>
  </section>

  <!-- Featured Case Studies -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal mb-4">Real Results</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">See how we've delivered measurable ROI for finance and accounting teams.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {sortedFeatured.map((study) => (
          <CaseStudyCard
            industry={study.data.industry}
            metric={study.data.metric || study.data.summary}
            description={study.data.shortDescription || study.data.summary}
            link={`/case-studies#${study.id}`}
          />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/case-studies" class="inline-flex items-center gap-2 text-amber-dark hover:text-amber font-semibold">
          View All Case Studies
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-semibold text-charcoal">Proven in Finance Operations</h2>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-amber mb-2">30+</div>
          <div class="text-sm text-gray-600">Years Finance Operations Experience</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">Fortune 500</div>
          <div class="text-sm text-gray-600">Manufacturing & Industrial</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">Utilities</div>
          <div class="text-sm text-gray-600">Healthcare & Insurance</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">100+</div>
          <div class="text-sm text-gray-600">Processes Automated</div>
        </div>
      </div>
      
      <div class="text-center mt-12 text-sm text-gray-500">
        Systems expertise includes SAP, Workday, NetSuite, Ariba, Lawson, Hyperion, 
        and advanced Excel, VBA & Power Query solutions.
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a 30-minute discovery call. We'll identify your highest-impact automation opportunities."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
