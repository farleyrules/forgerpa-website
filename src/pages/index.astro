---
import PageLayout from '../layouts/PageLayout.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
import { getCollection } from 'astro:content';
const featuredStudies = await getCollection('case-studies', ({ data }) => data.featured === true);
const sortedFeatured = featuredStudies
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 3);
---

<PageLayout
  title="Finance & Accounting Automation | Forge RPA"
  description="Practical automation for finance and accounting teams. We help companies of all sizes eliminate manual work in month-end close, AP processing, reconciliations, and reporting."
  heroTitle="Enterprise Finance Automation"
  heroSubtitle="Proprietary framework combining 30 years of financial operations expertise with self-improving automation systems. Proven in finance but applicable to other operational processes. We help Controllers, CFOs, and finance teams eliminate manual work in month-end close, accounts payable, reconciliations, and reporting — with solutions that actually work in production."
  heroCta="Book a Discovery Call"
  heroCtaLink="/book"
>
  <!-- Proof Bar -->
  <ProofBar />

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">What We Build</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Specialized automation for finance and accounting processes — from quick assessments to full system implementations. Whether you're a growing business or an established enterprise, we help finance teams eliminate manual work and focus on higher-value activities.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ServiceCard
          icon="📊"
          title="Automation Assessment"
          description="Data-driven process scoring and ROI projections specifically designed for finance and accounting teams. Our framework identifies which processes will deliver the fastest return."
          link="/services/automation-assessment"
        />
        <ServiceCard
          icon="🔄"
          title="ERP Data Migration"
          description="Reliable data conversion for Workday, NetSuite, SAP and other systems. Reconciliation-verified accuracy with minimal disruption."
          link="/services/erp-data-migration"
        />
        <ServiceCard
          icon="⚙️"
          title="Finance Process Automation"
          description="Our proprietary framework rapidly transforms complex finance processes into reliable, self-improving automation with built-in governance and documentation."
          link="/services/sop-automation"
        />
        <ServiceCard
          icon="🔍"
          title="Process Mining"
          description="Data-driven discovery of how your finance processes actually work. Our framework identifies bottlenecks, exceptions, and high-ROI automation opportunities from real transaction data."
          link="/services/process-mining"
        />
      </div>
    </div>
  </section>

  <!-- Featured Case Studies -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal mb-4">Real Results</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">See how we've delivered measurable ROI for finance and accounting teams.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {sortedFeatured.map((study) => (
          <CaseStudyCard
            industry={study.data.industry}
            metric={study.data.metric || study.data.summary}
            description={study.data.shortDescription || study.data.summary}
            link={`/case-studies#${study.id}`}
          />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/case-studies" class="inline-flex items-center gap-2 text-amber-dark hover:text-amber font-semibold">
          View All Case Studies
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">Industries we serve</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Finance-grade automation with clear audit trails — plus operations handoffs that feed the ledger. Explore by industry or small business; every org still has core A&amp;F and ops pain we can map on a call.
        </p>
        <a href="/industries" class="inline-flex mt-6 text-amber-dark hover:text-amber font-semibold">
          View all industry pages →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <a href="/industries/oil-gas" class="block rounded-2xl border border-gray-100 bg-white p-6 hover:border-amber transition-colors">
          <h3 class="text-lg font-bold text-charcoal mb-2">Oil &amp; gas</h3>
          <p class="text-sm text-gray-600">Finance, JVs, and operations handoffs (materials, field, logistics).</p>
        </a>
        <a href="/industries/healthcare-finance" class="block rounded-2xl border border-gray-100 bg-white p-6 hover:border-amber transition-colors">
          <h3 class="text-lg font-bold text-charcoal mb-2">Healthcare Finance &amp; Ops</h3>
          <p class="text-sm text-gray-600">Non-PHI finance and adjacent ops (supplies, facilities feeds).</p>
        </a>
        <a href="/industries/insurance-finance" class="block rounded-2xl border border-gray-100 bg-white p-6 hover:border-amber transition-colors">
          <h3 class="text-lg font-bold text-charcoal mb-2">Insurance</h3>
          <p class="text-sm text-gray-600">Finance, claims ops files, and underwriting support assembly.</p>
        </a>
        <a href="/industries/utilities-finance" class="block rounded-2xl border border-gray-100 bg-white p-6 hover:border-amber transition-colors">
          <h3 class="text-lg font-bold text-charcoal mb-2">Utilities</h3>
          <p class="text-sm text-gray-600">Close, work orders, field events, and regulatory extracts.</p>
        </a>
        <a href="/industries/small-business" class="block rounded-2xl border border-gray-100 bg-white p-6 hover:border-amber transition-colors">
          <h3 class="text-lg font-bold text-charcoal mb-2">Small and Growing Businesses</h3>
          <p class="text-sm text-gray-600">Assessment first, per-solution builds, optional retainer without an IT bench.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-semibold text-charcoal">Proven in Finance Operations</h2>
        <p class="text-gray-600 mt-3">Deep finance domain expertise developed through 30 years in financial operations, controllership, and systems transformation. Proven in finance but applicable to other operational processes.</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-amber mb-2">30+</div>
          <div class="text-sm text-gray-600">Years in Financial Controllership & Operations</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">Fortune 500</div>
          <div class="text-sm text-gray-600">Manufacturing & Industrial Companies</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">Multiple Industries</div>
          <div class="text-sm text-gray-600">Utilities, Healthcare & Insurance</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-amber mb-2">100+</div>
          <div class="text-sm text-gray-600">Finance Processes Automated</div>
        </div>
      </div>
      
      <div class="text-center mt-12 text-sm text-gray-500 max-w-2xl mx-auto">
        Extensive experience with SAP, Workday, NetSuite, Ariba, Lawson, Hyperion, 
        and advanced Excel, VBA & Power Query solutions — now enhanced with modern automation approaches.
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a 30-minute discovery call. We'll identify your highest-impact automation opportunities."
    ctaText="Book a Discovery Call"
    ctaLink="/book"
  />
</PageLayout>
