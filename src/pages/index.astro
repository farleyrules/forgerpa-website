---
import PageLayout from '../layouts/PageLayout.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
---

<PageLayout
  title="Finance & Accounting Automation | ForgeRPA"
  description="Practical automation for finance and accounting teams. We help companies of all sizes eliminate manual work in month-end close, AP processing, reconciliations, and reporting."
  heroTitle="Finance Automation That Delivers Real Results"
  heroSubtitle="We combine deep finance operations experience with practical automation expertise to help companies of all sizes reduce manual work and improve accuracy."
  heroCta="Book a Discovery Call"
  heroCtaLink="/contact"
>
  <!-- Proof Bar -->
  <ProofBar />

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-slate-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-charcoal">What We Build</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Specialized automation for finance and accounting processes — from quick assessments to full system implementations. Whether you're a growing business or an established enterprise, we help finance teams eliminate manual work and focus on higher-value activities.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ServiceCard
          icon="📊"
          title="Automation Assessment"
          description="Not sure where to start? We score your processes, project the ROI, and show you exactly which automations will deliver the fastest return."
          link="/services/automation-assessment"
        />
        <ServiceCard
          icon="🔄"
          title="ERP Data Migration"
          description="Reliable data conversion for Workday, NetSuite, SAP and other systems. Reconciliation-verified accuracy with minimal disruption."
          link="/services/erp-data-migration"
        />
        <ServiceCard
          icon="⚙️"
          title="SOP Automation"
          description="Turn your documented procedures into working automation. Faster implementation with solutions that match how your team actually works."
          link="/services/sop-automation"
        />
        <ServiceCard
          icon="🔍"
          title="Process Mining"
          description="Discover how work actually gets done. Identify bottlenecks, inefficiencies, and high-ROI automation opportunities."
          link="/services/process-mining"
        />
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Reduce Manual Finance Work?"
    subtext="Book a 30-minute discovery call. We'll identify your highest-impact automation opportunities."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
