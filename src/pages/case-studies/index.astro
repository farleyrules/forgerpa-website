---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');

// Sort by order field (lower number = shown first)
const sortedCaseStudies = caseStudies.sort((a, b) => 
  (a.data.order || 999) - (b.data.order || 999)
);
---

<PageLayout
  title="Case Studies"
  description="Real automation results from real engagements. See how Forge RPA helps companies streamline operations and reduce costs."
  heroTitle="Results That Speak"
  heroSubtitle="Real outcomes from real engagements."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      {sortedCaseStudies.map((study) => (
        <article class="scroll-mt-24" id={study.id}>
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 text-xs font-semibold bg-charcoal text-amber rounded-full">{study.data.industry}</span>
            <span class="text-sm text-gray-500">{study.data.service}</span>
          </div>
          
          <h2 class="text-3xl font-bold text-charcoal mb-4">{study.data.title}</h2>
          <p class="text-xl text-amber-dark font-semibold mb-8">{study.data.summary}</p>

          <div class="space-y-8">
            <div>
              <h3 class="text-xl font-bold text-charcoal mb-3">Challenge</h3>
              <p class="text-gray-700 leading-relaxed">{study.data.challenge}</p>
            </div>

            <div>
              <h3 class="text-xl font-bold text-charcoal mb-3">Approach</h3>
              <p class="text-gray-700 leading-relaxed">{study.data.approach}</p>
            </div>

            <div>
              <h3 class="text-xl font-bold text-charcoal mb-3">Outcome</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {study.data.outcome.map((item) => (
                  <div class="flex items-start gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-amber-dark flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    heading="Let Us Show You What's Possible"
    subtext="Book a free 30-minute discovery call. We will identify your top automation candidates and estimate the ROI."
    ctaText="Book a Discovery Call"
    ctaLink="/contact"
  />
</PageLayout>
