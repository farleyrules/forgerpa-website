---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

const { title, description = 'Intelligent automation built by a CPA who codes. Finance process automation, Workday conversion, and AI-powered assessment.', canonicalUrl } = Astro.props;
const siteUrl = 'https://forgerpa.com';
const canonical = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="ForgeRPA" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <title>{title} | ForgeRPA</title>
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body class="bg-white text-gray-900 font-sans antialiased">
  <slot />
</body>
</html>
