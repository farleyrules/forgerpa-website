# Copy to .env for local builds (optional). For production, set these in Cloudflare Pages → Settings → Environment variables.

# Cloudflare API (used by wrangler deploy — see DEPLOY.md)
# CLOUDFLARE_API_TOKEN=

# Optional: Formspree endpoint for the Resources page "Email me the toolkit links" form.
# Create a form at https://formspree.io/ and paste the form URL (e.g. https://formspree.io/f/xxxxxxxx).
# Must be available at **build** time for static HTML (use same var in Cloudflare Pages → Environment variables for Production).
# PUBLIC_FORMSPREE_TOOLKIT=https://formspree.io/f/xxxxxxxx
